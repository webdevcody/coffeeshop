{
  "name": "coffeeshop",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Multiplayer 3D coffeeshop — walk around, chat, and talk over WebRTC voice.",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "server": "node server/server.js",
    "start": "node server/server.js",
    "check": "node scripts/check-syntax.js",
    "test:collision": "node scripts/collision-test.mjs",
    "test:props": "node scripts/props-in-road-test.mjs",
    "test:ws": "PORT=8090 node scripts/ws-test.mjs",
    "test:game": "PORT=8092 node scripts/game-room-test.mjs",
    "test:e2e": "npm run build && node scripts/browser-test.mjs",
    "test": "npm run check && node scripts/collision-test.mjs && node scripts/props-in-road-test.mjs && node scripts/ws-test.mjs && npm run test:game && npm run test:e2e"
  },
  "dependencies": {
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "playwright": "^1.61.0",
    "three": "0.160.0",
    "vite": "^6.0.0"
  }
}
